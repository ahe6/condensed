generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ProductStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum ProductPurchaseMode {
  DIRECT
  ASSESSMENT_REQUIRED
}

enum AssessmentTemplateStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum AssessmentQuestionType {
  SINGLE_SELECT
  MULTI_SELECT
  TEXT
  NUMBER
  BOOLEAN
}

enum AssessmentTemplateType {
  PRODUCT_INTAKE
  GOAL_INTAKE
}

enum AssessmentSubmissionStatus {
  SUBMITTED
  REVIEW_REQUIRED
  APPROVED
  REJECTED
}

enum CheckoutAuthorizationStatus {
  ACTIVE
  USED
  EXPIRED
  REVOKED
}

enum AssessmentRecommendationStatus {
  RECOMMENDED
  SELECTED
  DISMISSED
}

enum OrderStatus {
  PENDING
  PLACED
  CANCELLED
  REFUNDED
}

enum PaymentStatus {
  UNPAID
  AUTHORIZED
  PAID
  FAILED
  EXPIRED
  REFUNDED
  DISPUTED
}

enum PaymentStatusEventSource {
  SYSTEM
  ADMIN_MANUAL
  ADMIN_SYNC
  STRIPE_WEBHOOK
}

enum PaymentAttemptStatus {
  OPEN
  COMPLETED
  EXPIRED
  FAILED
  CANCELED
}

enum ShipmentStatusEventSource {
  SYSTEM
  ADMIN_MANUAL
}

enum ShipmentTrackingEventSource {
  SYSTEM
  ADMIN_MANUAL
}

enum FulfillmentStatus {
  UNFULFILLED
  PARTIAL
  FULFILLED
  RETURNED
}

enum NotificationType {
  SHIPMENT_DELIVERED
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
  SKIPPED
}

enum AddressType {
  SHIPPING
  BILLING
}

enum ShipmentStatus {
  PENDING
  SHIPPED
  DELIVERED
  RETURNED
}

model User {
  id                     String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  externalAuthId         String?                 @unique
  email                  String                  @unique
  name                   String?
  phone                  String?
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  addresses              Address[]
  assessmentSubmissions  AssessmentSubmission[]
  carts                  Cart[]
  checkoutAuthorizations CheckoutAuthorization[]
  orders                 Order[]

  @@map("users")
}

model Address {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId            String   @db.Uuid
  label             String?
  recipientName     String
  line1             String
  line2             String?
  city              String
  state             String?
  postalCode        String
  country           String   @db.Char(2)
  phone             String?
  isDefaultShipping Boolean  @default(false)
  isDefaultBilling  Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("addresses")
}

model Product {
  id                        String                     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  slug                      String                     @unique
  name                      String
  description               String?
  status                    ProductStatus              @default(DRAFT)
  purchaseMode              ProductPurchaseMode        @default(DIRECT)
  createdAt                 DateTime                   @default(now())
  updatedAt                 DateTime                   @updatedAt
  variants                  ProductVariant[]
  images                    ProductImage[]
  categories                ProductCategory[]
  orderItems                OrderItem[]
  assessmentTemplates       AssessmentTemplate[]
  assessmentSubmissions     AssessmentSubmission[]
  checkoutAuthorizations    CheckoutAuthorization[]
  assessmentRecommendations AssessmentRecommendation[]

  @@index([status])
  @@map("products")
}

model AssessmentTemplate {
  id          String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productId   String?                  @db.Uuid
  goalKey     String?
  slug        String
  title       String
  description String?
  type        AssessmentTemplateType   @default(PRODUCT_INTAKE)
  status      AssessmentTemplateStatus @default(DRAFT)
  version     Int                      @default(1)
  createdAt   DateTime                 @default(now())
  updatedAt   DateTime                 @updatedAt
  product     Product?                 @relation(fields: [productId], references: [id], onDelete: Cascade)
  questions   AssessmentQuestion[]
  submissions AssessmentSubmission[]

  @@unique([slug, version])
  @@index([productId, status, version])
  @@index([type, goalKey, status, version])
  @@map("assessment_templates")
}

model AssessmentQuestion {
  id         String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  templateId String                 @db.Uuid
  key        String
  label      String
  helpText   String?
  type       AssessmentQuestionType
  required   Boolean                @default(true)
  options    Json?
  sortOrder  Int                    @default(0)
  createdAt  DateTime               @default(now())
  updatedAt  DateTime               @updatedAt
  template   AssessmentTemplate     @relation(fields: [templateId], references: [id], onDelete: Cascade)
  answers    AssessmentAnswer[]

  @@unique([templateId, key])
  @@index([templateId, sortOrder])
  @@map("assessment_questions")
}

model AssessmentSubmission {
  id                     String                     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  templateId             String                     @db.Uuid
  productId              String?                    @db.Uuid
  goalKey                String?
  userId                 String?                    @db.Uuid
  email                  String?
  status                 AssessmentSubmissionStatus @default(SUBMITTED)
  decisionReason         String?
  decisionPolicyId       String?
  decisionPolicyVersion  Int?
  decidedAt              DateTime?
  submittedAt            DateTime                   @default(now())
  createdAt              DateTime                   @default(now())
  updatedAt              DateTime                   @updatedAt
  template               AssessmentTemplate         @relation(fields: [templateId], references: [id], onDelete: Restrict)
  product                Product?                   @relation(fields: [productId], references: [id], onDelete: Restrict)
  user                   User?                      @relation(fields: [userId], references: [id], onDelete: SetNull)
  answers                AssessmentAnswer[]
  checkoutAuthorizations CheckoutAuthorization[]
  recommendations        AssessmentRecommendation[]

  @@index([templateId, submittedAt])
  @@index([productId, submittedAt])
  @@index([goalKey, submittedAt])
  @@index([userId, submittedAt])
  @@index([status, submittedAt])
  @@map("assessment_submissions")
}

model AssessmentAnswer {
  id           String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  submissionId String               @db.Uuid
  questionId   String               @db.Uuid
  questionKey  String
  value        Json
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  submission   AssessmentSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  question     AssessmentQuestion   @relation(fields: [questionId], references: [id], onDelete: Restrict)

  @@unique([submissionId, questionKey])
  @@index([questionId])
  @@map("assessment_answers")
}

model ProductVariant {
  id                     String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productId              String                  @db.Uuid
  sku                    String                  @unique
  title                  String
  price                  Decimal                 @db.Decimal(12, 2)
  currency               String                  @default("USD") @db.Char(3)
  inventoryQuantity      Int                     @default(0)
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  product                Product                 @relation(fields: [productId], references: [id], onDelete: Cascade)
  cartItems              CartItem[]
  checkoutAuthorizations CheckoutAuthorization[]
  orderItems             OrderItem[]

  @@index([productId])
  @@map("product_variants")
}

model CheckoutAuthorization {
  id                     String                      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId                 String                      @db.Uuid
  productId              String                      @db.Uuid
  variantId              String?                     @db.Uuid
  assessmentSubmissionId String                      @db.Uuid
  status                 CheckoutAuthorizationStatus @default(ACTIVE)
  expiresAt              DateTime
  usedAt                 DateTime?
  createdAt              DateTime                    @default(now())
  updatedAt              DateTime                    @updatedAt
  user                   User                        @relation(fields: [userId], references: [id], onDelete: Cascade)
  product                Product                     @relation(fields: [productId], references: [id], onDelete: Restrict)
  variant                ProductVariant?             @relation(fields: [variantId], references: [id], onDelete: Restrict)
  assessmentSubmission   AssessmentSubmission        @relation(fields: [assessmentSubmissionId], references: [id], onDelete: Cascade)

  @@index([userId, productId, status, expiresAt])
  @@index([assessmentSubmissionId])
  @@index([variantId])
  @@map("checkout_authorizations")
}

model AssessmentRecommendation {
  id                     String                         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  assessmentSubmissionId String                         @db.Uuid
  productId              String                         @db.Uuid
  status                 AssessmentRecommendationStatus @default(RECOMMENDED)
  rank                   Int
  reasonCode             String
  reasonText             String?
  sourcePolicyId         String
  sourcePolicyVersion    Int
  selectedAt             DateTime?
  dismissedAt            DateTime?
  createdAt              DateTime                       @default(now())
  updatedAt              DateTime                       @updatedAt
  assessmentSubmission   AssessmentSubmission           @relation(fields: [assessmentSubmissionId], references: [id], onDelete: Cascade)
  product                Product                        @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@unique([assessmentSubmissionId, productId])
  @@index([assessmentSubmissionId, rank])
  @@index([productId])
  @@map("assessment_recommendations")
}

model ProductImage {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productId String   @db.Uuid
  url       String
  altText   String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("product_images")
}

model Category {
  id        String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  parentId  String?           @db.Uuid
  slug      String            @unique
  name      String
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  parent    Category?         @relation("CategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children  Category[]        @relation("CategoryTree")
  products  ProductCategory[]

  @@index([parentId])
  @@map("categories")
}

model ProductCategory {
  productId  String   @db.Uuid
  categoryId String   @db.Uuid
  createdAt  DateTime @default(now())
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([productId, categoryId])
  @@index([categoryId])
  @@map("product_categories")
}

model Cart {
  id        String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String?    @db.Uuid
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  user      User?      @relation(fields: [userId], references: [id], onDelete: SetNull)
  items     CartItem[]

  @@index([userId])
  @@map("carts")
}

model CartItem {
  id        String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cartId    String         @db.Uuid
  variantId String         @db.Uuid
  quantity  Int
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  cart      Cart           @relation(fields: [cartId], references: [id], onDelete: Cascade)
  variant   ProductVariant @relation(fields: [variantId], references: [id], onDelete: Restrict)

  @@unique([cartId, variantId])
  @@index([variantId])
  @@map("cart_items")
}

model Order {
  id                     String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId                 String?                 @db.Uuid
  orderNumber            String                  @unique
  email                  String
  status                 OrderStatus             @default(PENDING)
  paymentStatus          PaymentStatus           @default(UNPAID)
  fulfillmentStatus      FulfillmentStatus       @default(UNFULFILLED)
  currency               String                  @default("USD") @db.Char(3)
  subtotal               Decimal                 @default(0) @db.Decimal(12, 2)
  discountTotal          Decimal                 @default(0) @db.Decimal(12, 2)
  shippingTotal          Decimal                 @default(0) @db.Decimal(12, 2)
  taxTotal               Decimal                 @default(0) @db.Decimal(12, 2)
  total                  Decimal                 @default(0) @db.Decimal(12, 2)
  placedAt               DateTime?
  reservationExpiresAt   DateTime?
  inventoryReleasedAt    DateTime?
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  user                   User?                   @relation(fields: [userId], references: [id], onDelete: SetNull)
  addresses              OrderAddress[]
  items                  OrderItem[]
  payments               Payment[]
  paymentAttempts        PaymentAttempt[]
  paymentStatusEvents    PaymentStatusEvent[]
  shipmentStatusEvents   ShipmentStatusEvent[]
  shipmentTrackingEvents ShipmentTrackingEvent[]
  notes                  OrderNote[]
  shipments              Shipment[]
  notificationEvents     NotificationEvent[]

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@index([reservationExpiresAt])
  @@index([inventoryReleasedAt])
  @@map("orders")
}

model OrderAddress {
  id            String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId       String      @db.Uuid
  type          AddressType
  recipientName String
  line1         String
  line2         String?
  city          String
  state         String?
  postalCode    String
  country       String      @db.Char(2)
  phone         String?
  createdAt     DateTime    @default(now())
  order         Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@unique([orderId, type])
  @@map("order_addresses")
}

model OrderItem {
  id            String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId       String          @db.Uuid
  productId     String?         @db.Uuid
  variantId     String?         @db.Uuid
  productName   String
  variantTitle  String?
  sku           String
  unitPrice     Decimal         @db.Decimal(12, 2)
  quantity      Int
  total         Decimal         @db.Decimal(12, 2)
  createdAt     DateTime        @default(now())
  order         Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product       Product?        @relation(fields: [productId], references: [id], onDelete: SetNull)
  variant       ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
  shipmentItems ShipmentItem[]

  @@index([orderId])
  @@index([productId])
  @@index([variantId])
  @@map("order_items")
}

model OrderNote {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId     String   @db.Uuid
  body        String
  authorEmail String?
  createdAt   DateTime @default(now())
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId, createdAt])
  @@map("order_notes")
}

model Payment {
  id                String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId           String               @db.Uuid
  provider          String
  providerPaymentId String?
  status            PaymentStatus        @default(UNPAID)
  amount            Decimal              @db.Decimal(12, 2)
  currency          String               @default("USD") @db.Char(3)
  processedAt       DateTime?
  metadata          Json?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  order             Order                @relation(fields: [orderId], references: [id], onDelete: Cascade)
  attempts          PaymentAttempt[]
  statusEvents      PaymentStatusEvent[]

  @@unique([provider, providerPaymentId])
  @@index([orderId])
  @@map("payments")
}

model PaymentAttempt {
  id                      String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  paymentId               String               @db.Uuid
  orderId                 String               @db.Uuid
  provider                String
  providerAttemptId       String
  providerPaymentIntentId String?
  status                  PaymentAttemptStatus @default(OPEN)
  amount                  Decimal              @db.Decimal(12, 2)
  currency                String               @default("USD") @db.Char(3)
  expiresAt               DateTime?
  completedAt             DateTime?
  expiredAt               DateTime?
  failedAt                DateTime?
  canceledAt              DateTime?
  metadata                Json?
  createdAt               DateTime             @default(now())
  updatedAt               DateTime             @updatedAt
  payment                 Payment              @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  order                   Order                @relation(fields: [orderId], references: [id], onDelete: Cascade)
  statusEvents            PaymentStatusEvent[]

  @@unique([provider, providerAttemptId])
  @@unique([provider, providerPaymentIntentId])
  @@index([paymentId])
  @@index([orderId])
  @@index([status])
  @@index([expiresAt])
  @@map("payment_attempts")
}

model PaymentStatusEvent {
  id               String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  paymentId        String                   @db.Uuid
  paymentAttemptId String?                  @db.Uuid
  orderId          String                   @db.Uuid
  fromStatus       PaymentStatus?
  toStatus         PaymentStatus
  source           PaymentStatusEventSource
  providerEventId  String?
  providerObjectId String?
  reason           String?
  metadata         Json?
  createdAt        DateTime                 @default(now())
  payment          Payment                  @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  paymentAttempt   PaymentAttempt?          @relation(fields: [paymentAttemptId], references: [id], onDelete: SetNull)
  order            Order                    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@unique([providerEventId])
  @@index([paymentAttemptId, createdAt])
  @@index([paymentId, createdAt])
  @@index([orderId, createdAt])
  @@index([providerObjectId])
  @@map("payment_status_events")
}

model Shipment {
  id             String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId        String                  @db.Uuid
  carrier        String?
  trackingNumber String?
  status         ShipmentStatus          @default(PENDING)
  shippedAt      DateTime?
  deliveredAt    DateTime?
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt
  order          Order                   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  items          ShipmentItem[]
  statusEvents   ShipmentStatusEvent[]
  trackingEvents ShipmentTrackingEvent[]
  notifications  NotificationEvent[]

  @@index([orderId])
  @@index([trackingNumber])
  @@map("shipments")
}

model ShipmentItem {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  shipmentId  String    @db.Uuid
  orderItemId String    @db.Uuid
  quantity    Int
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  shipment    Shipment  @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  orderItem   OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)

  @@unique([shipmentId, orderItemId])
  @@index([orderItemId])
  @@map("shipment_items")
}

model ShipmentStatusEvent {
  id         String                    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  shipmentId String                    @db.Uuid
  orderId    String                    @db.Uuid
  fromStatus ShipmentStatus?
  toStatus   ShipmentStatus
  source     ShipmentStatusEventSource
  reason     String?
  metadata   Json?
  createdAt  DateTime                  @default(now())
  shipment   Shipment                  @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  order      Order                     @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([shipmentId, createdAt])
  @@index([orderId, createdAt])
  @@map("shipment_status_events")
}

model ShipmentTrackingEvent {
  id                 String                      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  shipmentId         String                      @db.Uuid
  orderId            String                      @db.Uuid
  fromCarrier        String?
  toCarrier          String?
  fromTrackingNumber String?
  toTrackingNumber   String?
  source             ShipmentTrackingEventSource
  reason             String?
  metadata           Json?
  createdAt          DateTime                    @default(now())
  shipment           Shipment                    @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  order              Order                       @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([shipmentId, createdAt])
  @@index([orderId, createdAt])
  @@map("shipment_tracking_events")
}

model NotificationEvent {
  id                String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId           String             @db.Uuid
  shipmentId        String?            @db.Uuid
  type              NotificationType
  recipientEmail    String
  status            NotificationStatus @default(PENDING)
  provider          String?
  providerMessageId String?
  errorMessage      String?
  sentAt            DateTime?
  metadata          Json?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  order             Order              @relation(fields: [orderId], references: [id], onDelete: Cascade)
  shipment          Shipment?          @relation(fields: [shipmentId], references: [id], onDelete: Cascade)

  @@unique([shipmentId, type])
  @@index([orderId, createdAt])
  @@index([shipmentId, createdAt])
  @@index([status, createdAt])
  @@map("notification_events")
}
