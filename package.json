{
  "name": "health",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/backend",
    "apps/frontend"
  ],
  "scripts": {
    "backend:dev": "npm --workspace apps/backend run dev",
    "backend:build": "npm --workspace apps/backend run build",
    "backend:start": "npm --workspace apps/backend run start",
    "backend:check": "npm --workspace apps/backend run check",
    "dev:local": "scripts/local-dev.sh",
    "dev:local:restart": "scripts/local-dev.sh --restart",
    "frontend:dev": "npm --workspace apps/frontend run dev",
    "frontend:dev:aws": "scripts/frontend-dev-aws.sh",
    "frontend:build": "npm --workspace apps/frontend run build",
    "frontend:start": "npm --workspace apps/frontend run start",
    "frontend:check": "npm --workspace apps/frontend run check",
    "test:stripe-checkout": "scripts/restock-dev-mug.sh && playwright test tests/stripe-checkout.spec.ts --project=local-chrome",
    "stripe:reconcile-checkouts": "npm --workspace apps/backend run stripe:reconcile-checkouts",
    "notifications:retry": "npm --workspace apps/backend run notifications:retry",
    "db:migrate": "npm --workspace apps/backend run prisma:migrate",
    "db:deploy": "npm --workspace apps/backend run prisma:deploy",
    "db:generate": "npm --workspace apps/backend run prisma:generate",
    "db:studio": "npm --workspace apps/backend run prisma:studio"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0"
  }
}
